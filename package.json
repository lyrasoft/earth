{
    "name": "windwalker",
    "private": true,
    "scripts": {
        "dev": "vite",
        "build": "vite build --mode development",
        "build:prod": "vite build",
        "watch": "vite build --watch --mode development",
        "postinstall": "yarn build -- install",
        "upgrade": "yarn up '**' -R"
    },
    "dependencies": {
        "@fortawesome/fontawesome-free": "^7.0",
        "@lyrasoft/luna": "portal:./vendor/lyrasoft/luna/assets",
        "@popperjs/core": "^2.11.8",
        "@windwalker-io/core": "^4.0",
        "@windwalker-io/fusion-next": "^0.1.0",
        "@windwalker-io/srp": "^1.0",
        "@windwalker-io/unicorn-next": "^0.1.0",
        "bootstrap": "^5.0.0",
        "cross-env": "^7.0.3",
        "vite": "^8.0"
    },
    "workspaces": [
        "vendor/windwalker/unicorn/*",
        "vendor/windwalker/core/assets/*"
    ],
    "//": {
        "workspaces": [
            "vendor/windwalker/unicorn/*",
            "vendor/windwalker/core/assets/*"
        ]
    },
    "packageManager": "yarn@4.13.0+sha512.5c20ba010c99815433e5c8453112165e673f1c7948d8d2b267f4b5e52097538658388ebc9f9580656d9b75c5cc996f990f611f99304a2197d4c56d21eea370e7"
}
